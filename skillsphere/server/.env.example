## SkillSphere Server (.env)

# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# CORS allowlist (comma-separated). Include your Vercel domain in production.
# Example: CORS_ORIGINS=http://localhost:5173,https://skillsphere-phi.vercel.app
CORS_ORIGINS=

# Database
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me
JWT_EXPIRE=7d

# Google OAuth
GOOGLE_CLIENT_ID=

# Email (Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="SkillSphere <no-reply@skillsphere.com>"

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET_KEY=

# Optional strict mode
REQUIRE_EMAIL_VERIFIED=false

